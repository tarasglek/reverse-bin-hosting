# Default deployment-specific settings for reverse-bin.
#
# Update these values to match your public DNS and ACME contact address,
# then restart the service:
#   sudo systemctl restart reverse-bin.service

OPS_EMAIL=admin@example.com
DOMAIN_SUFFIX=example.com

# Select the Caddy config used by the systemd unit.
# Use Caddyfile.acme for public HTTPS with on-demand ACME certificates.
# Use Caddyfile.http-only behind a trusted proxy/tunnel such as Cloudflare Tunnel.
REVERSE_BIN_CADDYFILE=/etc/reverse-bin/Caddyfile.acme

# HTTP-only listener port. Only used by Caddyfile.http-only.
REVERSE_BIN_HTTP_PORT=7777

# Shared backend lifecycle defaults used by every packaged reverse-bin block.
REVERSE_BIN_IDLE_TIMEOUT_MS=300000
REVERSE_BIN_HEALTH_TIMEOUT_MS=15000
REVERSE_BIN_TERMINATION_GRACE_MS=5000
REVERSE_BIN_TERMINATION_KILL_WAIT_MS=1000
