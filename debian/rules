#!/usr/bin/make -f

export DH_VERBOSE=1
export PATH := /usr/local/go/bin:$(PATH)
CADDY_REVERSE_BIN_PLUGIN := github.com/tarasglek/caddy-reverse-bin@v0.2.1

%:
	dh $@

override_dh_auto_build:
	mkdir -p build
	xcaddy build --output build/reverse-bin-caddy --with $(CADDY_REVERSE_BIN_PLUGIN)
	install -m 0755 "$(shell command -v uv)" build/uv
	install -m 0755 "$(shell command -v landrun)" build/landrun
	install -m 0755 "$(shell command -v deno)" build/deno
	install -m 0755 "$(shell command -v sops)" build/sops
	install -m 0755 "$(shell command -v age)" build/age
	install -m 0755 "$(shell command -v age-keygen)" build/age-keygen

override_dh_auto_test:

override_dh_dwz:

override_dh_auto_install:
	dh_auto_install

override_dh_installsystemd:
	dh_installsystemd --no-enable --no-start
